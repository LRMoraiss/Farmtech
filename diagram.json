{
  "version": 1,
  "author": "Manus AI - EmbarcaTech FarmTech Project",
  "title": "FarmTech Autonomous System - BitDogLab Simulation",
  "description": "Simulação do sistema autônomo de gestão de ambiente para cultivo hidropônico",
  "width": 800,
  "height": 600,
  "parts": [
    {
      "type": "wokwi-pi-pico",
      "id": "pico",
      "top": 200,
      "left": 100,
      "attrs": {
        "name": "Raspberry Pi Pico"
      }
    },
    {
      "type": "wokwi-analog-joystick",
      "id": "joystick",
      "top": 50,
      "left": 400,
      "attrs": {
        "name": "Joystick Analógico"
      }
    },
    {
      "type": "wokwi-pushbutton",
      "id": "button-a",
      "top": 150,
      "left": 400,
      "attrs": {
        "name": "Botão A (Água)"
      }
    },
    {
      "type": "wokwi-pushbutton",
      "id": "button-b",
      "top": 250,
      "left": 400,
      "attrs": {
        "name": "Botão B (Dia/Noite)"
      }
    },
    {
      "type": "wokwi-ssd1306",
      "id": "oled",
      "top": 50,
      "left": 600,
      "attrs": {
        "name": "Display OLED 128x64",
        "i2cAddress": "0x3c"
      }
    },
    {
      "type": "wokwi-neopixel-matrix",
      "id": "led-matrix",
      "top": 300,
      "left": 600,
      "attrs": {
        "name": "Matriz de LEDs WS2812B 5x5",
        "cols": 5,
        "rows": 5
      }
    }
  ],
  "connections": [
    [
      "pico:GP26",
      "joystick:VRx",
      "black"
    ],
    [
      "pico:GP27",
      "joystick:VRy",
      "black"
    ],
    [
      "pico:GP22",
      "joystick:SW",
      "black"
    ],
    [
      "pico:GP5",
      "button-a:1.pin",
      "black"
    ],
    [
      "pico:GND",
      "button-a:1.pin2",
      "black"
    ],
    [
      "pico:GP6",
      "button-b:1.pin",
      "black"
    ],
    [
      "pico:GND",
      "button-b:1.pin2",
      "black"
    ],
    [
      "pico:GP14",
      "oled:SDA",
      "green"
    ],
    [
      "pico:GP15",
      "oled:SCL",
      "green"
    ],
    [
      "pico:3V3",
      "oled:VCC",
      "red"
    ],
    [
      "pico:GND",
      "oled:GND",
      "black"
    ],
    [
      "pico:GP7",
      "led-matrix:DIN",
      "yellow"
    ],
    [
      "pico:3V3",
      "led-matrix:VCC",
      "red"
    ],
    [
      "pico:GND",
      "led-matrix:GND",
      "black"
    ]
  ]
}
