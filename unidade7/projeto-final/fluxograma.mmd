flowchart TD
    A([INÍCIO]) --> B[Inicializa Hardware\nADC, PWM, I2C, Wi-Fi]
    B --> C[Configura Timer de Interrupção\n1 segundo]
    C --> D{Loop Principal}

    D --> E[Lê Botão A]
    E --> F{Pressionado?}
    F -- Sim --> G[Alterna Bomba\nLIGADA / DESLIGADA]
    F -- Não --> H[Lê Botão B]
    G --> H

    H --> I{Pressionado?}
    I -- Sim --> J[Envia Telemetria\nvia UART / Wi-Fi]
    I -- Não --> K[Verifica Estado do Sistema]
    J --> K

    K --> L{Alarme Crítico?\nTemp > 35°C}
    L -- Sim --> M[LED Vermelho\nBuzzer Apita]
    L -- Não --> N{Atuadores Ativos?\nVentoinha ou Bomba}
    N -- Sim --> O[LED Azul]
    N -- Não --> P[LED Verde]

    M --> D
    O --> D
    P --> D

    subgraph INTERRUPÇÃO ["⏱ Interrupção de Timer (1s)"]
        T1[Lê Joystick X → Temperatura]
        T2[Lê Joystick Y → Umidade]
        T3{Temp > 35°C?}
        T4[Alarme Crítico = TRUE\nVentoinha = ON]
        T5{Temp > 28°C?}
        T6[Ventoinha = ON]
        T7[Ventoinha = OFF\nAlarme = FALSE]
        T1 --> T2 --> T3
        T3 -- Sim --> T4
        T3 -- Não --> T5
        T5 -- Sim --> T6
        T5 -- Não --> T7
    end
